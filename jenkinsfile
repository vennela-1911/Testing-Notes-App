pipeline {

    agent any

    options {

        timestamps()

        timeout(
            time: 60,
            unit: 'MINUTES'
        )
    }

    environment {

        EXECUTION_TYPE = "remote"
    }

    stages {

        stage('Install Dependencies') {

            steps {

                bat '''
                python -m pip install --upgrade pip
                python -m pip install -r "Automation/requirements.txt"
                '''
            }
        }

        stage('Clean Previous Reports') {

            steps {

                bat '''
                if exist "Automation\\reports\\allure-results" (
                    rmdir /s /q "Automation\\reports\\allure-results"
                )

                if exist "Automation\\reports\\allure-report" (
                    rmdir /s /q "Automation\\reports\\allure-report"
                )

                mkdir "Automation\\reports\\allure-results"
                '''
            }
        }

        stage('Run API Tests') {

            steps {

                catchError(
                    buildResult: 'UNSTABLE',
                    stageResult: 'FAILURE'
                ) {

                    bat '''
                    python -m pytest ^
                    "Automation/tests/api" ^
                    -v ^
                    --tb=short ^
                    --disable-warnings ^
                    --alluredir="Automation/reports/allure-results"
                    '''
                }
            }
        }

        stage('Run E2E Tests') {

            steps {

                catchError(
                    buildResult: 'UNSTABLE',
                    stageResult: 'FAILURE'
                ) {

                    bat '''
                    python -m pytest ^
                    "Automation/tests/e2e" ^
                    -v ^
                    --tb=short ^
                    --disable-warnings ^
                    --alluredir="Automation/reports/allure-results"
                    '''
                }
            }
        }

        stage('Run UI Tests') {

            steps {

                catchError(
                    buildResult: 'UNSTABLE',
                    stageResult: 'FAILURE'
                ) {

                    bat '''
                    python -m pytest ^
                    "Automation/tests/ui" ^
                    -v ^
                    --tb=short ^
                    --disable-warnings ^
                    --alluredir="Automation/reports/allure-results"
                    '''
                }
            }
        }

        stage('Run AI Tests') {

            steps {

                catchError(
                    buildResult: 'UNSTABLE',
                    stageResult: 'FAILURE'
                ) {

                    bat '''
                    python -m pytest ^
                    "Automation/tests/ai" ^
                    -v ^
                    --tb=short ^
                    --disable-warnings ^
                    --alluredir="Automation/reports/allure-results"
                    '''
                }
            }
        }

        stage('Generate Allure Report') {

            steps {

                allure(

                    includeProperties: false,

                    jdk: '',

                    results: [
                        [
                            path: 'Automation/reports/allure-results'
                        ]
                    ]
                )
            }
        }
    }

    post {

        always {

            archiveArtifacts(

                artifacts: 'Automation/reports/screenshots/*.png',

                allowEmptyArchive: true
            )
        }

        success {

            echo 'Pipeline executed successfully.'
        }

        unstable {

            echo 'Some test cases failed. Build marked as UNSTABLE.'
        }

        failure {

            echo 'Pipeline execution failed.'
        }
    }
}